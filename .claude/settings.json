{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(uv sync)",
      "Bash(uv run pytest*)",
      "Bash(uv run ruff check .)",
      "Bash(uv run mypy src)",
      "Bash(uv run uvicorn competitionops.main:app --reload)",
      "Bash(uv run python -m competitionops_mcp.server)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(docker compose*)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Read(./**)",
      "Write(./src/**)",
      "Write(./tests/**)",
      "Write(./docs/**)",
      "Write(./infra/**)",
      "Write(./scripts/**)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Bash(rm -rf *)",
      "Bash(kubectl delete *)",
      "Bash(kubectl apply *)",
      "Bash(gcloud auth print-access-token*)",
      "Bash(cat ~/.config/gcloud/*)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "console",
    "OTEL_LOGS_EXPORTER": "console"
  }
}
